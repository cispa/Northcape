CONFIG_BASE64=y
CONFIG_INCLUDE_RESET_VECTOR=y
CONFIG_CONSOLE=y
CONFIG_SERIAL=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_NS16550=y
CONFIG_UART_NS16550_ACCESS_WORD_ONLY=y
CONFIG_CONSOLE_HANDLER=y
CONFIG_XIP=n
CONFIG_INIT_STACKS=y
CONFIG_SYS_CLOCK_TICKS_PER_SEC=12500000
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=12500000
CONFIG_FPU=n
CONFIG_POWEROFF=y

# PTP RTC
CONFIG_PTP_CLOCK_HA1588=y
CONFIG_PTP_CLOCK_HA1588_TSU=y

# RNG
CONFIG_TIMER_RANDOM_GENERATOR=y
CONFIG_TEST_RANDOM_GENERATOR=y

# IRQs
CONFIG_MULTI_LEVEL_INTERRUPTS=y
CONFIG_2ND_LEVEL_INTERRUPTS=y
# 1 PLIC
CONFIG_NUM_2ND_LEVEL_AGGREGATORS=1
CONFIG_1ST_LEVEL_INTERRUPT_BITS=7
CONFIG_2ND_LEVEL_INTERRUPT_BITS=23
CONFIG_PLIC=y
CONFIG_3RD_LEVEL_INTERRUPTS=n
CONFIG_3RD_LEVEL_INTERRUPT_BITS=0

# pulp timer
CONFIG_PULP_APB_TIMER=y

# must initialize ASAP, before other devices
# should be loaded before devices that rely on it, so should be initialized first
CONFIG_INTC_INIT_PRIORITY=0


# required for the DMA to work properly...
CONFIG_SOC_SERIES_CV64A6_PROVIDE_NONSTANDARD_CACHE_OPTIONS=y

# debug
CONFIG_DEBUG=y
CONFIG_DEBUG_OPTIMIZATIONS=y
# CONFIG_NO_OPTIMIZATIONS=y
# TODO collides with Skadi stacks at the moment
CONFIG_STACK_SENTINEL=n
CONFIG_LOG=y
# the more sophisticated modes somehow cause a read error...
CONFIG_LOG_MODE_MINIMAL=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_THREAD_NAME=y
CONFIG_DEBUG_THREAD_INFO=y
# CONFIG_ASSERT=y

# earliest-possible console
CONFIG_EARLY_CONSOLE=y
CONFIG_SERIAL_INIT_PRIORITY=0
CONFIG_CONSOLE_INIT_PRIORITY=1

CONFIG_ISR_STACK_SIZE=4096
CONFIG_MAIN_STACK_SIZE=4096
CONFIG_SYSTEM_WORKQUEUE_STACK_SIZE=4096
CONFIG_IDLE_STACK_SIZE=4096

# TLS not currently available with Skadi
CONFIG_CURRENT_THREAD_USE_TLS=n

# libc
CONFIG_PICOLIBC_USE_MODULE=y
# not supported yet
CONFIG_THREAD_LOCAL_STORAGE=n

# needed for drivers to compile
CONFIG_DEVICE_STORE_DT_ID=y

# config options to test the scheduler interrupt
# forces timer ticks a few times per second, running the timer interrupt
# CONFIG_TICKLESS_KERNEL=n
CONFIG_SYS_CLOCK_TICKS_PER_SEC=1000
CONFIG_RISCV_GP=n

# not exported
CONFIG_SPIN_VALIDATE=n

# net
CONFIG_ETH_XILINX_AXI_ETHERNET_LITE=y
CONFIG_MDIO=y
CONFIG_PHY_GENERIC_MII=y
CONFIG_MDIO_XILINX_AXI_ETHERNET_LITE=y

CONFIG_ETH_DRIVER=y
CONFIG_NET_L2_ETHERNET=y
